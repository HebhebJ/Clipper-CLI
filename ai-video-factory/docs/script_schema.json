{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-video-factory/script.schema.json",
  "title": "AI Video Factory Script",
  "type": "object",
  "required": [
    "topic",
    "duration_seconds",
    "tone",
    "language",
    "scenes"
  ],
  "properties": {
    "topic": { "type": "string" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "tone": { "type": "string" },
    "language": { "type": "string" },
    "title": { "type": "string" },
    "hook": { "type": "string" },
    "script_id": { "type": "string" },
    "raw_text_path": { "type": "string" },
    "json_path": { "type": "string" },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scene" }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "start", "end", "voice_text"],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "voice_text": { "type": "string" },
        "visual_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "on_screen_text": { "type": "string" }
      }
    }
  }
}
